import torch
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig
from peft import PeftModel


BASE_MODEL_ID = "Qwen/Qwen2.5-8B"
LORA_ADAPTER_PATH = "./percorso_del_suo_adattatore_lora_ottimizzato" # Modificare con il path corretto
INPUT_FILE = "../data/dataset/test_en.txt"
OUTPUT_FILE = "../data/model_outputs/post_tuning_qwen_8b_optm.txt"

bnb_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_use_double_quant=True,
    bnb_4bit_quant_type="nf4",
    bnb_4bit_compute_dtype=torch.bfloat16
)

tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL_ID)
base_model = AutoModelForCausalLM.from_pretrained(
    BASE_MODEL_ID,
    quantization_config=bnb_config,
    device_map="auto"
)

model = PeftModel.from_pretrained(base_model, LORA_ADAPTER_PATH)

def translate_text(text):
    messages = [
        {"role": "system", "content": "You are a professional translator. Translate the following text into Italian. Provide ONLY the translation, without any notes or explanations."},
        {"role": "user", "content": text}
    ]
    prompt = tokenizer.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    inputs = tokenizer(prompt, return_tensors="pt").to("cuda")
    
    outputs = model.generate(
        **inputs, 
        max_new_tokens=256,
        temperature=0.1,
        do_sample=True
    )
    return tokenizer.decode(outputs[0][inputs['input_ids'].shape[1]:], skip_special_tokens=True).strip()


with open(INPUT_FILE, "r", encoding="utf-8") as f_in, open(OUTPUT_FILE, "w", encoding="utf-8") as f_out:
    lines = f_in.readlines()
    for i, line in enumerate(lines):
        source_text = line.strip()
        if source_text:
            translation = translate_text(source_text)
            f_out.write(translation + "\n")


print("Estrazione completata.")
